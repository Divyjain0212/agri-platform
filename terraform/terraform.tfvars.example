# Example terraform.tfvars file
# Copy this to terraform.tfvars and fill in your values

aws_region   = "ap-south-1"
environment  = "production"
project_name = "agri-platform"

vpc_cidr = "10.0.0.0/16"

app_name   = "agri-platform"
app_port   = 8000

# Docker image URI from ECR
# Replace with your actual image: 123456789.dkr.ecr.ap-south-1.amazonaws.com/agri-platform:latest
container_image = "123456789.dkr.ecr.ap-south-1.amazonaws.com/agri-platform:latest"

container_cpu    = 512
container_memory = 1024

min_capacity = 2
max_capacity = 10

db_instance_class = "db.t3.micro"
db_username       = "agriuser"
db_password       = "password"

# Django superuser credentials for admin panel access
django_superuser_username = "admin"
django_superuser_email    = "admin@agri-platform.com"
django_superuser_password = "ChangeMe@123" # Change this to a strong password 
